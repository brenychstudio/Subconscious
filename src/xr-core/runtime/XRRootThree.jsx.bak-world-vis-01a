const clamp01 = (x) => Math.max(0, Math.min(1, x));
const lerp = (a, b, t) => a + (b - a) * t;

function disposeMaterial(material) {
  if (!material) return;
  if (Array.isArray(material)) {
    material.forEach(disposeMaterial);
    return;
  }
  if (material.map) material.map.dispose?.();
  if (material.alphaMap) material.alphaMap.dispose?.();
  material.dispose?.();
}

function disposeObjectTree(root) {
  if (!root) return;
  root.traverse((obj) => {
    if (obj.geometry) obj.geometry.dispose?.();
    if (obj.material) disposeMaterial(obj.material);
  });
}

function makeAdditiveMaterial(color, opacity) {
  return new THREE.MeshBasicMaterial({
    color,
    transparent: true,
    opacity,
    depthWrite: false,
    blending: THREE.AdditiveBlending,
    side: THREE.DoubleSide,
  });
}

function createParticleField() {
  const count = 900;
  const positions = new Float32Array(count * 3);

  for (let i = 0; i < count; i += 1) {
    positions[i * 3 + 0] = (Math.random() - 0.5) * 46;
    positions[i * 3 + 1] = Math.random() * 9 + 0.2;
    positions[i * 3 + 2] = -Math.random() * 42 + 7;
  }

  const geometry = new THREE.BufferGeometry();
  geometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));

  const material = new THREE.PointsMaterial({
    color: 0x9fb7ee,
    size: 0.028,
    transparent: true,
    opacity: 0.16,
    depthWrite: false,
    blending: THREE.AdditiveBlending,
    sizeAttenuation: true,
  });

  return new THREE.Points(geometry, material);
}

function createTransitionField(fromRoom, toRoom) {
  const group = new THREE.Group();

  const midX = (fromRoom.x + toRoom.x) * 0.5;
  const midZ = (fromRoom.z + toRoom.z) * 0.5;
  group.position.set(midX, 0, midZ);

  const dx = toRoom.x - fromRoom.x;
  const dz = toRoom.z - fromRoom.z;
  const angle = Math.atan2(dx, dz);
  group.rotation.y = angle;

  const veilCount = 3;

  for (let i = 0; i < veilCount; i += 1) {
    const t = veilCount === 1 ? 0.5 : i / (veilCount - 1);
    const xOffset = lerp(-0.7, 0.7, t);

    const veil = new THREE.Mesh(
      new THREE.PlaneGeometry(1.35, 3.4),
      makeAdditiveMaterial(0x88a7ff, 0.045)
    );
    veil.position.set(xOffset, 1.75, 0);
    group.add(veil);
  }

  const ring = new THREE.Mesh(
    new THREE.TorusGeometry(0.9, 0.018, 12, 72),
    makeAdditiveMaterial(0xa2bcff, 0.12)
  );
  ring.rotation.x = Math.PI / 2;
  ring.position.set(0, 0.08, 0);
  group.add(ring);

  return group;
}

