function buildRoomEntry(room) {
  if (room.id === "hall-of-arrival") return createArrivalRoom(room);
  if (room.id === "signal-corridor") return createSignalRoom(room);
  if (room.id === "membrane-chamber") return createMembraneRoom(room);
  if (room.id === "portal-atrium") return createPortalRoom(room);
  return createArrivalRoom(room);
}

export default function XRRootThree({ manifest, options, xrSupported, xrChecked, worldRuntime }) {
  const hostRef = useRef(null);

  useEffect(() => {
    const host = hostRef.current;
    if (!host) return;

    host.innerHTML = "";
    host.style.position = "relative";
    host.style.background = WORLD_VISUALS.baseBg;
    host.style.overflow = "hidden";

    const width = Math.max(1, host.clientWidth);
    const height = Math.max(1, host.clientHeight);

    const scene = new THREE.Scene();
    scene.background = new THREE.Color(WORLD_VISUALS.baseBg);
    scene.fog = new THREE.FogExp2(WORLD_VISUALS.baseBg, WORLD_VISUALS.fogDensity);

    const camera = new THREE.PerspectiveCamera(66, width / height, 0.01, 220);
    camera.position.set(0, 1.68, 0);

    const rig = new THREE.Group();
    rig.position.set(0, 0, 3.9);
    rig.add(camera);
    scene.add(rig);

    const renderer = new THREE.WebGLRenderer({
      antialias: true,
      alpha: false,
      powerPreference: "high-performance",
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, options?.quality?.maxDpr ?? 1.5));
    renderer.setSize(width, height);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 0.92;
    renderer.xr.enabled = true;
    host.appendChild(renderer.domElement);

    const vrButton = VRButton.createButton(renderer);
    if (xrSupported) {
      host.appendChild(vrButton);
    } else {
      vrButton.style.display = "none";
    }

    const ritualSound = createRitualSoundEngine();
    const voiceSeed = createVoiceSeedEngine();

    const pointerLock = new PointerLockControls(camera, renderer.domElement);
    pointerLock.pointerSpeed = options?.timings?.mouseLookSpeed ?? 0.28;

    const voiceBadge = document.createElement("div");
    voiceBadge.style.position = "absolute";
    voiceBadge.style.right = "16px";
    voiceBadge.style.top = "16px";
    voiceBadge.style.zIndex = "21";
    voiceBadge.style.padding = "8px 10px";
    voiceBadge.style.fontSize = "9px";
    voiceBadge.style.letterSpacing = "0.16em";
    voiceBadge.style.textTransform = "uppercase";
    voiceBadge.style.color = "rgba(255,255,255,0.76)";
    voiceBadge.style.background = "rgba(8,12,20,0.30)";
    voiceBadge.style.border = "1px solid rgba(255,255,255,0.10)";
    voiceBadge.style.backdropFilter = "blur(8px)";
    voiceBadge.style.webkitBackdropFilter = "blur(8px)";
    voiceBadge.style.userSelect = "none";
    voiceBadge.style.cursor = "pointer";
    voiceBadge.textContent = "Voice · Off · V";
    host.appendChild(voiceBadge);

    const updateVoiceBadge = (state) => {
      if (state?.error) {
        voiceBadge.textContent = "Voice Seed · Error";
        return;
      }

      if (!state?.enabled) {
        voiceBadge.textContent = "Voice Seed · Off · press V";
        return;
      }

      if (state?.calibrating) {
        voiceBadge.textContent = "Voice Seed · Calibrating";
        return;
      }

      if (state?.active) {
        voiceBadge.textContent = "Voice Seed · Listening";
        return;
      }

      voiceBadge.textContent = "Voice Seed · Enabled";
    };

    const enableSound = async () => {
      await ritualSound.resume();
    };

    const onHostClick = async () => {
      await enableSound();

      if (!renderer.xr.isPresenting && document.pointerLockElement !== renderer.domElement) {
        pointerLock.lock();
      }
    };

    const toggleVoice = async () => {
      await enableSound();
      const state = await voiceSeed.toggle();
      updateVoiceBadge(state);
    };

    const onKeyDown = async (event) => {
      if (event.code === "KeyV") {
        event.preventDefault();
        await toggleVoice();
      }
    };

    host.addEventListener("click", onHostClick);
    voiceBadge.addEventListener("click", toggleVoice);
    window.addEventListener("keydown", onKeyDown);

    const hemi = new THREE.HemisphereLight(0xdce7ff, 0x04070d, 0.72);
    scene.add(hemi);

    const dir = new THREE.DirectionalLight(0xffffff, 0.38);
    dir.position.set(2.8, 5.9, 4.8);
    scene.add(dir);

    const ambient = new THREE.AmbientLight(0x8aa4d8, 0.12);
    scene.add(ambient);

    const floorMat = new THREE.MeshStandardMaterial({
      color: new THREE.Color(WORLD_VISUALS.floorColor),
      roughness: 0.985,
      metalness: 0.02,
      emissive: new THREE.Color(WORLD_VISUALS.floorEmissive),
      emissiveIntensity: WORLD_VISUALS.floorEmissiveIntensity,
    });

    const floor = new THREE.Mesh(new THREE.PlaneGeometry(320, 320), floorMat);
    floor.rotation.x = -Math.PI / 2;
    floor.position.y = 0;
    scene.add(floor);

const particleField = createParticleField();
    scene.add(particleField);

    const stillnessTracker = createStillnessProtoTracker();
    const stillnessField = createStillnessField();
    scene.add(stillnessField.group);

    const spacing = options?.layout?.spacing ?? 7.2;
    const curveAmp = options?.layout?.curveAmp ?? 0.62;
    const curveX = (index) => Math.sin(index * 0.72) * curveAmp;

    const runtimeRooms = roomRegistry.map((room, index) => ({
      ...room,
      index,
      x: curveX(index),
      z: room.z ?? (1.2 - index * spacing),
      preset: getRoomPreset(room.id),
    }));

    const zStart = runtimeRooms[0]?.z ?? 1.2;
    const zEnd = runtimeRooms[runtimeRooms.length - 1]?.z ?? -21.4;
    const midZ = (zStart + zEnd) * 0.5;

    const environment = createEnvironmentShell({
      scene,
      stage: "sea",
      works: [],
      spacing,
      zStart,
      zEnd,
      midZ,
      curveX,
      hazeBaseOpacity: WORLD_VISUALS.hazeBaseOpacity,
    });

    const interaction = createInteractionShell({ mount: host });
    interaction.setDesktopHint("Click to enter · WASD move · click once for sound · V voice");
    interaction.setDesktopHintVisible(true);
    interaction.setVRHint("Look to focus · Trigger to teleport");
    interaction.setVRHintVisible(false);

    const runtimeState = createInitialWorldState();
    const worldPos = new THREE.Vector3();
    let unlockedPortalT = 0;

    const syncWorldRoom = (room) => {
      if (!room || !worldRuntime) return;

      try {
        if (typeof worldRuntime.recordRoomEntry === "function") {
          worldRuntime.recordRoomEntry(room.id, "xr-room-focus");
          return;
        }

        if (typeof worldRuntime.markVisited === "function") {
          worldRuntime.markVisited(room.id);
        }
      } catch {}
    };

    const syncWorldPortal = (portalId) => {
      if (!portalId || !worldRuntime) return;

      try {
        if (typeof worldRuntime.recordPortalUnlock === "function") {
          worldRuntime.recordPortalUnlock(portalId, "xr-portal-proximity");
          return;
        }

        if (typeof worldRuntime.openPortal === "function") {
          worldRuntime.openPortal(portalId);
        }
      } catch {}
    };

    if (typeof window !== "undefined") {
      window.__WHISPER_WORLD_BINDING__ = {
        getCurrentRoomId: () => runtimeState.currentRoomId,
        getUnlockedPortalIds: () => Array.from(runtimeState.unlockedPortalIds ?? []),
        getMemoryMarks: () =>
          worldRuntime && typeof worldRuntime.snapshot === "function"
            ? worldRuntime.snapshot().state.memoryMarks
            : [],
      };
    }

let latestVoiceState = {
      enabled: false,
      active: false,
      calibrating: false,
      energy: 0,
      brightness: 0,
      onset: 0,
      breath: 0,
      presence: 0,
      bloom: 0,
      error: null,
    };

    let latestStillnessState = {
      motionStillness: 0,
      silence: 0,
      stillness: 0,
      settled: 0,
    };

    let activeStillRoom = runtimeRooms[0];
    let activeStillProgress = 0;

    const roomEntries = runtimeRooms.map((room) => {
      const entry = buildRoomEntry(room);
      const sculpture = createVoiceSculptureProto(room.id);
      entry.group.add(sculpture.group);
      entry.sculpture = sculpture;
      scene.add(entry.group);
      return entry;
    });

    const transitionFields = [];
    for (let i = 0; i < runtimeRooms.length - 1; i += 1) {
      const field = createTransitionField(runtimeRooms[i], runtimeRooms[i + 1]);
      transitionFields.push(field);
      scene.add(field);
    }

    const portalConfig = portalRegistry[0];
    const finalRoom = runtimeRooms[runtimeRooms.length - 1];
    const portalZ = (finalRoom?.z ?? -21.4) + (portalConfig?.zOffset ?? -4.2);

    const gateCue = createGateCue({
      scene,
      dir,
      hemi,
      floorMat,
      getBaseDirIntensity: () => 0.38,
      getBaseHemiIntensity: () => 0.72,
      getBaseFloorEmissive: () => WORLD_VISUALS.floorEmissiveIntensity,
    });

    gateCue.createAt({ x: 0, z: portalZ });
    const gate = gateCue.getGate();
    if (gate) gate.visible = true;

    const portalGroup = new THREE.Group();
    portalGroup.position.set(0, 0, portalZ);

    const portalFloorRing = new THREE.Mesh(
      new THREE.RingGeometry(1.12, 1.42, 72),
      makeAdditiveMaterial(0xe4edff, 0.18)
    );
    portalFloorRing.rotation.x = -Math.PI / 2;
    portalFloorRing.position.y = 0.03;
    portalGroup.add(portalFloorRing);

    const portalHalo = new THREE.Mesh(
      new THREE.TorusGeometry(1.02, 0.03, 18, 120),
      makeAdditiveMaterial(0xdce8ff, 0.24)
    );
    portalHalo.position.set(0, 1.84, 0);
    portalGroup.add(portalHalo);

    const portalCore = new THREE.Mesh(
      new THREE.CircleGeometry(0.86, 72),
      makeAdditiveMaterial(0xb2c8ff, 0.05)
    );
    portalCore.position.set(0, 1.84, -0.03);
    portalGroup.add(portalCore);

scene.add(portalGroup);

    const portalInvocation = createPortalInvocationProto();
    portalGroup.add(portalInvocation.group);

    const locomotion = createLocomotionShell({
      scene,
      renderer,
      camera,
      rig,
      floor,
      snapTurnDeg: options?.locomotion?.snapTurnDeg ?? 30,
      snapCooldownMs: options?.locomotion?.snapCooldownMs ?? 320,
      markerColor: 0x9bbcff,
    });

    const handPresence = createHandPresenceSystem({
      scene,
      renderer,
    });

    const handVisualProxy = createHandVisualProxySystem({
      handPresence,
    });

    const handContactReadiness = createHandContactReadinessSystem({
      scene,
      handPresence,
    });

    if (typeof window !== "undefined") {
      window.__WHISPER_HANDS__ = handPresence;
      window.__WHISPER_HAND_VISUALS__ = handVisualProxy;
      window.__WHISPER_HAND_CONTACT__ = handContactReadiness;
    }

    const onResize = () => {
      const w = Math.max(1, host.clientWidth);
      const h = Math.max(1, host.clientHeight);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    };

    window.addEventListener("resize", onResize);

    const clock = new THREE.Clock();

    const setCurrentRoom = (room) => {
      if (!room) return;

      const changed = runtimeState.currentRoomId !== room.id;
      runtimeState.currentRoomId = room.id;
      runtimeState.visitedRoomIds.add(room.id);

      if (changed) {
        syncWorldRoom(room);
      } else if (
        worldRuntime &&
        typeof worldRuntime.getCurrentRoom === "function" &&
        worldRuntime.getCurrentRoom()?.id !== room.id
      ) {
        syncWorldRoom(room);
      }
    };

    const updateArrival = (entry, elapsed, emphasis, voice) => {
      const { core, crownA, crownB, groundRingA, groundRingB } = entry.elements;
      const wave = 0.5 + Math.sin(elapsed * 1.2) * 0.5;
      const p = emphasis * voice.presence;
      const b = voice.bloom;
      const br = voice.brightness;

      core.scale.setScalar(1 + wave * 0.24 + emphasis * 0.16 + p * 0.34 + b * 0.18);
      core.material.opacity = 0.42 + wave * 0.22 + emphasis * 0.12 + p * 0.12 + b * 0.1;

      crownA.rotation.z += 0.005 + voice.onset * 0.006;
      crownA.material.opacity = 0.1 + wave * 0.1 + emphasis * 0.07 + br * 0.08 + b * 0.06;

      crownB.rotation.z -= 0.003 + voice.breath * 0.003;
      crownB.material.opacity = 0.05 + wave * 0.07 + emphasis * 0.04 + p * 0.05;

      groundRingA.material.opacity = 0.09 + wave * 0.06 + emphasis * 0.05 + voice.onset * 0.05;
      groundRingB.material.opacity = 0.04 + wave * 0.04 + emphasis * 0.03 + b * 0.04;
    };

    const updateSignal = (entry, elapsed, emphasis, voice) => {
      const { rods, waveRing, floorTrace } = entry.elements;
      rods.forEach((rod, i) => {
        const wave = 0.5 + Math.sin(elapsed * 2.25 + i * 0.48) * 0.5;
        rod.position.y = 1.05 + wave * 0.64 + voice.presence * 0.22 + voice.onset * 0.1;
        rod.material.opacity = 0.04 + wave * 0.14 + emphasis * 0.07 + voice.onset * 0.06 + voice.brightness * 0.04;
      });

      waveRing.rotation.z += 0.012 + voice.onset * 0.01;
      waveRing.scale.setScalar(1 + voice.presence * 0.1 + voice.bloom * 0.06);
      waveRing.material.opacity = 0.04 + emphasis * 0.08 + Math.sin(elapsed * 1.8) * 0.02 + voice.brightness * 0.06;

      floorTrace.material.opacity = 0.05 + emphasis * 0.07 + Math.sin(elapsed * 1.5) * 0.02 + voice.onset * 0.04;
    };

    const updateMembrane = (entry, elapsed, emphasis, voice) => {
      const { membraneCore, membraneAura, veils, floorRing } = entry.elements;

      const readiness = membraneCore.userData?.__handReadiness ?? null;
      const handProximity = readiness?.aggregateProximity ?? 0;
      const handContact = readiness?.aggregateContact ?? 0;
      const dwellMs = readiness?.dwellMs ?? 0;
      const dwellT = Math.min(1, dwellMs / 1400);
      const coherence = readiness?.coherence ?? 0;
      const bothHands = readiness?.bothHandsActive ? 1 : 0;

      const leftProx = readiness?.hands?.left?.proximityIntensity ?? 0;
      const rightProx = readiness?.hands?.right?.proximityIntensity ?? 0;
      const leftContact = readiness?.hands?.left?.contactIntensity ?? 0;
      const rightContact = readiness?.hands?.right?.contactIntensity ?? 0;

      const directionalBias =
        (rightProx + rightContact * 0.85) -
        (leftProx + leftContact * 0.85);

      const handCharge =
        handProximity * 0.34 +
        handContact * 0.88 +
        dwellT * 0.42 +
        coherence * 0.34 +
        bothHands * 0.14;

      const directedLift =
        handProximity * 0.12 +
        handContact * 0.18 +
        dwellT * 0.14 +
        coherence * 0.10;

      membraneCore.position.x = directionalBias * 0.11;
      membraneAura.position.x = directionalBias * 0.14;

      const sx =
        1 +
        Math.sin(elapsed * 1.1) * 0.08 +
        emphasis * 0.14 +
        voice.presence * 0.18 +
        handProximity * 0.10 +
        handContact * 0.18 +
        bothHands * 0.08 +
        coherence * 0.06;

      const sy =
        1 +
        Math.cos(elapsed * 1.42) * 0.16 +
        emphasis * 0.18 +
        voice.breath * 0.18 +
        voice.bloom * 0.08 +
        handProximity * 0.14 +
        handContact * 0.24 +
        dwellT * 0.18 +
        coherence * 0.12 +
        bothHands * 0.08;

      const sz =
        1 +
        Math.sin(elapsed * 0.9 + 0.7) * 0.09 +
        emphasis * 0.14 +
        voice.presence * 0.14 +
        handProximity * 0.10 +
        handContact * 0.16 +
        coherence * 0.08;

      membraneCore.scale.set(sx, sy, sz);
      membraneCore.material.opacity =
        0.04 +
        emphasis * 0.08 +
        Math.sin(elapsed * 1.3) * 0.02 +
        voice.presence * 0.08 +
        voice.bloom * 0.04 +
        handProximity * 0.08 +
        handContact * 0.12 +
        dwellT * 0.08 +
        coherence * 0.05;

      const auraScale =
        1 +
        Math.sin(elapsed * 0.86) * 0.05 +
        emphasis * 0.12 +
        voice.brightness * 0.14 +
        voice.bloom * 0.08 +
        handProximity * 0.12 +
        handContact * 0.18 +
        dwellT * 0.16 +
        coherence * 0.10 +
        bothHands * 0.06;

      membraneAura.scale.setScalar(auraScale);
      membraneAura.rotation.y += 0.005 + voice.onset * 0.008 + handCharge * 0.006;
      membraneAura.rotation.z = directionalBias * 0.22;
      membraneAura.material.opacity =
        0.03 +
        emphasis * 0.05 +
        Math.sin(elapsed * 1.1) * 0.02 +
        voice.brightness * 0.06 +
        handProximity * 0.06 +
        handContact * 0.10 +
        dwellT * 0.08 +
        coherence * 0.04;

      veils.forEach((veil, i) => {
        const centralBoost = i === 1 ? 1 : 0.64;
        const sideLift = i === 1 ? directionalBias * 0.08 : directionalBias * 0.05;

        veil.position.x = sideLift;
        veil.position.y =
          1.9 +
          Math.sin(elapsed * 1.2 + i * 0.8) * 0.1 +
          voice.breath * 0.08 +
          handProximity * 0.05 * centralBoost +
          handContact * 0.08 * centralBoost +
          dwellT * 0.06 * centralBoost +
          coherence * 0.04 * centralBoost;

        veil.material.opacity =
          0.03 +
          emphasis * 0.04 +
          (i === 1 ? 0.03 : 0) +
          voice.presence * 0.04 +
          handProximity * 0.04 * centralBoost +
          handContact * 0.06 * centralBoost +
          dwellT * 0.04 * centralBoost +
          coherence * 0.03 * centralBoost;
      });

      floorRing.material.opacity =
        0.04 +
        emphasis * 0.07 +
        Math.sin(elapsed * 1.4) * 0.02 +
        voice.onset * 0.03 +
        voice.bloom * 0.03 +
        handProximity * 0.04 +
        handContact * 0.07 +
        dwellT * 0.05 +
        coherence * 0.03;

      floorRing.scale.setScalar(
        1 +
        handProximity * 0.04 +
        handContact * 0.07 +
        dwellT * 0.05 +
        coherence * 0.03
      );

      entry.light.intensity =
        0.24 +
        emphasis * 0.16 +
        voice.presence * 0.08 +
        voice.bloom * 0.04 +
        handProximity * 0.10 +
        handContact * 0.16 +
        dwellT * 0.10 +
        coherence * 0.06 +
        bothHands * 0.05;

      entry.light.position.x = directionalBias * 0.26;
      entry.light.position.y = 2.4 + directedLift * 0.34;
    };

    const updatePortalRoom = (entry, elapsed, emphasis, voice) => {
      const { archOuter, archInner, membrane, pylons, floorRing } = entry.elements;

      const invocationDamp = clamp01(
        (voice.presence * 0.4 + voice.bloom * 0.28 + unlockedPortalT * 0.42) * emphasis
      );

      entry.shell.material.opacity = Math.max(
        0.014,
        entry.room.preset.shellOpacity + emphasis * 0.028 - invocationDamp * 0.045
      );

      entry.light.intensity =
        0.08 +
        emphasis * 0.12 +
        unlockedPortalT * 0.08 +
        voice.brightness * 0.03 +
        voice.bloom * 0.02;

      archOuter.rotation.z += 0.009 + voice.onset * 0.006;
      archOuter.material.opacity =
        0.07 +
        emphasis * 0.08 +
        unlockedPortalT * 0.08 +
        voice.brightness * 0.035 +
        voice.bloom * 0.025;

      archInner.rotation.z -= 0.014 + voice.breath * 0.004;
      archInner.material.opacity =
        0.04 +
        emphasis * 0.07 +
        unlockedPortalT * 0.09 +
        voice.presence * 0.035;

      const membraneScale =
        1 +
        Math.sin(elapsed * 1.65) * 0.04 +
        emphasis * 0.06 +
        unlockedPortalT * 0.08 +
        voice.presence * 0.06 +
        voice.bloom * 0.03;

      membrane.scale.setScalar(membraneScale);
      membrane.material.opacity =
        0.014 +
        emphasis * 0.03 +
        unlockedPortalT * 0.08 +
        voice.brightness * 0.035;

      pylons.forEach((pylon, i) => {
        const wave = 0.5 + Math.sin(elapsed * 1.9 + i * 0.9) * 0.5;
        pylon.material.opacity =
          0.025 +
          wave * 0.03 +
          emphasis * 0.03 +
          unlockedPortalT * 0.04 +
          voice.onset * 0.025;
      });

      floorRing.material.opacity =
        0.03 +
        emphasis * 0.05 +
        unlockedPortalT * 0.05 +
        voice.brightness * 0.02;
    };
    const updateRooms = (elapsed, voice) => {
      camera.getWorldPosition(worldPos);

      let nearest = null;
      let nearestDist = Infinity;
      const distances = new Map();

      roomEntries.forEach((entry) => {
        const dx = worldPos.x - entry.room.x;
        const dz = worldPos.z - entry.room.z;
        const dist = Math.sqrt(dx * dx + dz * dz);

        distances.set(entry.room.id, dist);

        if (dist < nearestDist) {
          nearestDist = dist;
          nearest = entry;
        }
      });

      const focusedProgress = nearest ? 1 - clamp01(nearestDist / 4.8) : 0;

      roomEntries.forEach((entry, index) => {
        const dist = distances.get(entry.room.id) ?? 999;
        const emphasis = clamp01(1 - dist / 5.6);
        const drift = Math.sin(elapsed * 0.42 + index * 0.7) * 0.04;
        const voiceInfluence = emphasis * voice.presence;
        const bloomInfluence = emphasis * voice.bloom;
        const focusBoost = nearest && nearest.room.id === entry.room.id
          ? focusedProgress
          : emphasis * 0.16;

        entry.group.position.y = drift;
        entry.shell.material.opacity = entry.room.preset.shellOpacity + emphasis * 0.04 + voiceInfluence * 0.025 + bloomInfluence * 0.012;
        entry.light.intensity = 0.12 + emphasis * 0.24 + Math.sin(elapsed * 1.1 + index * 0.5) * 0.05 + voiceInfluence * 0.18 + bloomInfluence * 0.08;

        if (entry.room.id === "hall-of-arrival") updateArrival(entry, elapsed, emphasis, voice);
        if (entry.room.id === "signal-corridor") updateSignal(entry, elapsed, emphasis, voice);
        if (entry.room.id === "membrane-chamber") updateMembrane(entry, elapsed, emphasis, voice);
        if (entry.room.id === "portal-atrium") updatePortalRoom(entry, elapsed, emphasis, voice);

        updateVoiceSculptureProto(entry.sculpture, {
          elapsed,
          voice,
          focus: focusBoost,
          portalUnlock: unlockedPortalT,
        });
      });

      transitionFields.forEach((field, index) => {
        const dx = worldPos.x - field.position.x;
        const dz = worldPos.z - field.position.z;
        const dist = Math.sqrt(dx * dx + dz * dz);
        const emphasis = clamp01(1 - dist / 6.4);

        field.position.y = Math.sin(elapsed * 0.36 + index * 0.6) * 0.06;
        field.children.forEach((child, childIndex) => {
          if (!child.material) return;
          child.material.opacity = 0.02 + emphasis * 0.05 + Math.sin(elapsed * 1.2 + childIndex) * 0.01 + voice.bloom * 0.02;
          if (child.geometry?.type === "TorusGeometry") {
            child.rotation.z += 0.004 + voice.onset * 0.004;
          }
        });
      });

const calmDamp = latestStillnessState.stillness * 0.7;

      particleField.rotation.y += (0.00045 + voice.onset * 0.0008) * (1 - calmDamp);
      particleField.position.z = Math.sin(elapsed * 0.08) * 0.6;
      particleField.material.opacity =
        Math.max(
          0.04,
          0.12 + voice.brightness * 0.04 + voice.bloom * 0.04 - latestStillnessState.stillness * 0.06
        );

      scene.fog.density =
        WORLD_VISUALS.fogDensity +
        voice.presence * 0.002 +
        voice.bloom * 0.0015 -
        latestStillnessState.stillness * 0.0016;

      renderer.toneMappingExposure =
        0.92 +
        voice.bloom * 0.035 -
        latestStillnessState.stillness * 0.028;

      if (!nearest) return;

      setCurrentRoom(nearest.room);

      const progress = focusedProgress;
      const boundRoom =
        worldRuntime && typeof worldRuntime.getCurrentRoom === "function"
          ? worldRuntime.getCurrentRoom() ?? nearest.room
          : nearest.room;

      interaction.setRail({
        pid: boundRoom.label ?? nearest.room.label,
        caption: boundRoom.caption ?? nearest.room.caption,
        visible: true,
        hintOpacity: 0.86,
      });
      interaction.setMeterProgress(progress);

activeStillRoom = nearest.room;
      activeStillProgress = progress;

      ritualSound.setRoomState(nearest.room.id, progress);
    };

    const updatePortal = (elapsed, dtSec, dtMs, voice) => {
      camera.getWorldPosition(worldPos);

      const dx = worldPos.x;
      const dz = worldPos.z - portalZ;
      const portalDist = Math.sqrt(dx * dx + dz * dz);

      if (portalDist < 3.8) {
        runtimeState.unlockedPortalIds.add(portalConfig.id);
        syncWorldPortal(portalConfig.id);
        gateCue.trigger();
      }

      const targetUnlock = runtimeState.unlockedPortalIds.has(portalConfig.id) ? 1 : 0;
      unlockedPortalT = lerp(unlockedPortalT, targetUnlock, clamp01(dtSec * 1.6));

      const portalNearness = 1 - clamp01(portalDist / 5.2);
      const portalVoiceLift =
        voice.presence * portalNearness * 0.16 +
        voice.bloom * portalNearness * 0.12 +
        voice.brightness * portalNearness * 0.08;

      ritualSound.setPortalPresence(
        Math.max(
          unlockedPortalT * 0.42,
          portalNearness * (0.18 + unlockedPortalT * 0.58) + portalVoiceLift
        )
      );

      portalFloorRing.material.opacity =
        0.035 +
        unlockedPortalT * 0.1 +
        Math.sin(elapsed * 1.4) * 0.012 +
        voice.onset * 0.01;

      portalHalo.rotation.z += dtMs * 0.00012 + voice.onset * 0.002;
      portalHalo.scale.setScalar(
        1 +
        unlockedPortalT * 0.04 +
        voice.bloom * 0.025
      );
      portalHalo.material.opacity =
        0.04 +
        unlockedPortalT * 0.12 +
        Math.sin(elapsed * 1.8) * 0.02 +
        voice.brightness * 0.025 +
        voice.bloom * 0.02;

      portalCore.scale.setScalar(
        0.84 +
        unlockedPortalT * 0.12 +
        voice.presence * 0.05 +
        voice.bloom * 0.03
      );
      portalCore.material.opacity =
        0.014 +
        unlockedPortalT * 0.08 +
        Math.sin(elapsed * 1.1) * 0.01 +
        voice.brightness * 0.025;

      updatePortalInvocationProto(portalInvocation, {
        elapsed,
        voice,
        focus: portalNearness,
        unlocked: unlockedPortalT,
      });

      gateCue.update(dtMs);
    };    renderer.setAnimationLoop(() => {
      const dtSec = clock.getDelta();
      const dtMs = dtSec * 1000;
      const elapsed = clock.elapsedTime;
      const nowMs = performance.now();

      latestVoiceState = voiceSeed.update();
      updateVoiceBadge(latestVoiceState);

      locomotion.updateTeleport();
      locomotion.updateDesktopMove(dtSec);
      locomotion.updateSnapTurn(nowMs);

updateRooms(elapsed, latestVoiceState);
      updatePortal(elapsed, dtSec, dtMs, latestVoiceState);

      latestStillnessState = stillnessTracker.update({
        camera,
        dtSec,
        voice: latestVoiceState,
      });

      updateStillnessField(stillnessField, {
        elapsed,
        room: activeStillRoom,
        stillness: latestStillnessState.stillness,
        settled: latestStillnessState.settled,
        progress: activeStillProgress,
      });

      ritualSound.setVoiceFeatures(latestVoiceState);
      ritualSound.update(elapsed);

      interaction.setVRHintVisible(Boolean(xrChecked && xrSupported && renderer.xr.isPresenting));
      interaction.setDesktopHintVisible(!renderer.xr.isPresenting);

      handPresence.update({
        currentRoomId: runtimeState.currentRoomId,
      });

      handContactReadiness.update({
        currentRoomId: runtimeState.currentRoomId,
        timeMs: performance.now(),
      });

      handVisualProxy.update({
        currentRoomId: runtimeState.currentRoomId,
        timeMs: performance.now(),
      });

      renderer.render(scene, camera);
    });

    return () => {
      renderer.setAnimationLoop(null);

      try { host.removeEventListener("click", onHostClick); } catch {}
      try { voiceBadge.removeEventListener("click", toggleVoice); } catch {}
      try { window.removeEventListener("keydown", onKeyDown); } catch {}
      try { window.removeEventListener("resize", onResize); } catch {}
      try { pointerLock.disconnect(); } catch {}

      try { locomotion.dispose(); } catch {}
      try { handContactReadiness.dispose(); } catch {}
      try { handVisualProxy.dispose(); } catch {}
      try { handPresence.dispose(); } catch {}
      try {
        if (typeof window !== "undefined") {
          delete window.__WHISPER_HANDS__;
          delete window.__WHISPER_HAND_VISUALS__;
          delete window.__WHISPER_HAND_CONTACT__;
        }
      } catch {}
      try { interaction.dispose(); } catch {}
      try { gateCue.dispose(); } catch {}
      try { environment.dispose(); } catch {}
      try { ritualSound.dispose(); } catch {}
      try { voiceSeed.dispose(); } catch {}

      try {
        disposeObjectTree(portalGroup);
        scene.remove(portalGroup);
      } catch {}

      transitionFields.forEach((field) => {
        try {
          disposeObjectTree(field);
          scene.remove(field);
        } catch {}
      });

      roomEntries.forEach((entry) => {
        try {
          disposeObjectTree(entry.group);
          scene.remove(entry.group);
        } catch {}
      });

try {
        disposeObjectTree(particleField);
        scene.remove(particleField);
      } catch {}

      try {
        disposeObjectTree(stillnessField.group);
        scene.remove(stillnessField.group);
      } catch {}

      try { stillnessTracker.dispose(); } catch {}

      try {
        floor.geometry.dispose();
        disposeMaterial(floor.material);
        scene.remove(floor);
      } catch {}

      try {
        renderer.dispose();
      } catch {}

      try {
        vrButton.remove();
      } catch {}

      try {
        voiceBadge.remove();
      } catch {}

      try {
        host.innerHTML = "";
      } catch {}
    };
  }, [manifest, options, xrSupported, xrChecked]);

  return <div ref={hostRef} style={{ width: "100%", height: "100%" }} />;
}



