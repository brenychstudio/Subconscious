import * as THREE from "three";
import { createStarSpriteTexture } from "./createStarSpriteTexture.js";
import {
  ARRIVAL_HERO_STARS,
  ARRIVAL_CONSTELLATION_GROUPS,
  ARRIVAL_SKY_DEBUG_INFO,
} from "./arrivalSkyCatalog.js";
import { getArrivalSkyPreset } from "./arrivalSkyPresets.js";

function clamp01(value) {
  return Math.min(1, Math.max(0, value));
}

function lerp(a, b, t) {
  return a + (b - a) * t;
}

function raDecToVector3(raHours, decDeg, radius) {
  const ra = (raHours / 24) * Math.PI * 2;
  const dec = THREE.MathUtils.degToRad(decDeg);

  const x = -radius * Math.cos(dec) * Math.sin(ra);
  const y = radius * Math.sin(dec);
  const z = -radius * Math.cos(dec) * Math.cos(ra);

  return new THREE.Vector3(x, y, z);
}

function createConstellationPlaceholder(radius) {
  const group = new THREE.Group();
  group.name = "arrival-constellation-placeholder";

  const material = new THREE.LineBasicMaterial({
    color: 0x7b96d8,
    transparent: true,
    opacity: 0.0,
    depthWrite: false,
    blending: THREE.AdditiveBlending,
  });

  ARRIVAL_CONSTELLATION_GROUPS.forEach((constellation) => {
    const positions = [];

    constellation.stars.forEach((starId) => {
      const star = ARRIVAL_HERO_STARS.find((item) => item.id === starId);
      if (!star) return;
      const point = raDecToVector3(star.ra, star.dec, radius);
      positions.push(point.x, point.y, point.z);
    });

    if (positions.length < 6) return;

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute(
      "position",
      new THREE.Float32BufferAttribute(positions, 3)
    );

    const line = new THREE.Line(geometry, material.clone());
    line.userData.emphasis = constellation.emphasis ?? 1;
    group.add(line);
  });

  return group;
}

function createHeroStarPlaceholder(radius, spriteTexture) {
  const group = new THREE.Group();
  group.name = "arrival-hero-stars";

  ARRIVAL_HERO_STARS.forEach((star) => {
    const material = new THREE.SpriteMaterial({
      map: spriteTexture,
      color: 0xe7efff,
      transparent: true,
      opacity: 0.0,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
    });

    const sprite = new THREE.Sprite(material);
    const point = raDecToVector3(star.ra, star.dec, radius);
    sprite.position.copy(point);

    const baseScale = star.mag < 0.6 ? 0.52 : 0.34;
    sprite.scale.setScalar(baseScale);

    sprite.userData.mag = star.mag;
    sprite.userData.id = star.id;

    group.add(sprite);
  });

  return group;
}

export function createArrivalCelestialSkySystem({
  presetId = "nightThreshold",
  initialRoomId = null,
} = {}) {
  const preset = getArrivalSkyPreset(presetId);
  const root = new THREE.Group();
  root.name = "arrival-celestial-sky-system";
  root.visible = true;

  const anchor = new THREE.Group();
  anchor.name = "arrival-celestial-sky-anchor";
  anchor.position.set(0, preset.anchorHeight, 0);
  root.add(anchor);

  const starTexture = createStarSpriteTexture();

  const farDome = new THREE.Group();
  farDome.name = "arrival-far-sky-layer";
  anchor.add(farDome);

  const heroStars = createHeroStarPlaceholder(preset.domeRadius - 1.5, starTexture);
  anchor.add(heroStars);

  const constellations = createConstellationPlaceholder(preset.domeRadius - 1.6);
  anchor.add(constellations);

  const state = {
    enabled: true,
    currentRoomId: initialRoomId,
    emphasis: 0,
    voice: {
      brightness: 0,
      bloom: 0,
      presence: 0,
    },
    viewer: {
      x: 0,
      y: 0,
      z: 0,
    },
    elapsed: 0,
  };

  const api = {
    group: root,
    preset,
    state,
    debugInfo: ARRIVAL_SKY_DEBUG_INFO,
    setEnabled(next) {
      state.enabled = Boolean(next);
      root.visible = state.enabled;
    },
    setRoom(roomId) {
      state.currentRoomId = roomId ?? null;
    },
    snapshot() {
      return {
        version: ARRIVAL_SKY_DEBUG_INFO.version,
        enabled: state.enabled,
        currentRoomId: state.currentRoomId,
        viewer: { ...state.viewer },
        emphasis: state.emphasis,
        voice: { ...state.voice },
        presetId,
      };
    },
  };

  root.userData.api = api;
  root.userData.kind = "ArrivalCelestialSkySystem";

  return api;
}

export function updateArrivalCelestialSkySystem(
  skySystem,
  {
    elapsed = 0,
    viewer = null,
    emphasis = 0,
    voice = null,
    roomId = null,
  } = {}
) {
  if (!skySystem || !skySystem.group) return;
  if (!skySystem.state.enabled) return;

  const { group, preset, state } = skySystem;
  const anchor = group.children[0];
  const heroStars = anchor?.children?.find((child) => child.name === "arrival-hero-stars");
  const constellations = anchor?.children?.find((child) => child.name === "arrival-constellation-placeholder");

  state.elapsed = elapsed;
  state.emphasis = clamp01(emphasis);

  if (roomId !== null) {
    state.currentRoomId = roomId;
  }

  if (viewer) {
    state.viewer.x = Number.isFinite(viewer.x) ? viewer.x : state.viewer.x;
    state.viewer.y = Number.isFinite(viewer.y) ? viewer.y : state.viewer.y;
    state.viewer.z = Number.isFinite(viewer.z) ? viewer.z : state.viewer.z;
  }

  if (voice) {
    state.voice.brightness = clamp01(voice.brightness ?? state.voice.brightness);
    state.voice.bloom = clamp01(voice.bloom ?? state.voice.bloom);
    state.voice.presence = clamp01(voice.presence ?? state.voice.presence);
  }

  anchor.position.x = lerp(anchor.position.x, state.viewer.x, preset.followLerp);
  anchor.position.y = lerp(anchor.position.y, state.viewer.y + preset.anchorHeight, preset.followLerp);
  anchor.position.z = lerp(anchor.position.z, state.viewer.z, preset.followLerp);

  anchor.rotation.y += preset.yawDrift;
  anchor.rotation.z = Math.sin(elapsed * 0.08) * preset.rollDriftAmplitude;

  if (heroStars) {
    heroStars.children.forEach((sprite, index) => {
      const wave = 0.5 + Math.sin(elapsed * (0.7 + index * 0.011)) * 0.5;
      const intensity =
        preset.heroOpacity +
        state.emphasis * 0.02 +
        state.voice.brightness * 0.02 +
        wave * 0.015;

      sprite.material.opacity = intensity;
    });
  }

  if (constellations) {
    constellations.children.forEach((line, index) => {
      const wave = 0.5 + Math.sin(elapsed * (0.28 + index * 0.013)) * 0.5;
      line.material.opacity =
        preset.constellationOpacity * (line.userData.emphasis ?? 1) * 0.5 +
        state.emphasis * 0.03 +
        state.voice.presence * 0.02 +
        wave * 0.01;
    });
  }
}

export function disposeArrivalCelestialSkySystem(skySystem) {
  if (!skySystem || !skySystem.group) return;

  skySystem.group.traverse((node) => {
    if (node.material) {
      if (Array.isArray(node.material)) {
        node.material.forEach((item) => item?.dispose?.());
      } else {
        node.material.dispose?.();
      }
    }

    if (node.geometry) {
      node.geometry.dispose?.();
    }

    if (node.material?.map) {
      node.material.map.dispose?.();
    }
  });

  if (skySystem.group.parent) {
    skySystem.group.parent.remove(skySystem.group);
  }
}
